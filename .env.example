# metaapi configuration. Copy to .env and fill in.

APP_PORT=8086

# Meta System User token (long-lived, from Business Settings → System Users).
# Must have ads_read + instagram_manage_messages (+ pages_show_list) and access
# to the ad account / IG-linked Pages.
META_ACCESS_TOKEN=
META_API_VERSION=v21.0
META_BUSINESS_ID=651286011395964
# Optional: pin one ad account (without the act_ prefix). Empty = auto-detect.
META_AD_ACCOUNT_ID=

# Auth (JWT) — MUST equal the marketing backend's JWT_SECRET so its login tokens
# validate here (unified auth; metaapi has no login of its own).
JWT_SECRET=dev-secret

# Serving. Point at the built SPA (dist) to serve the dashboard from this binary.
# Leave empty to run as API-only.
FRONTEND_DIR=
# Comma-separated allowed origins. Empty = allow all (fine behind one domain).
CORS_ORIGINS=
