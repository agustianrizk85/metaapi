# Copy to /opt/apps/meta.env on the server (outside git). Loaded by deploy.sh
# and passed to PM2 via --update-env.

APP_PORT=8098

# Meta System User token (long-lived). Same token used by the marketing app.
META_ACCESS_TOKEN=PASTE_SYSTEM_USER_TOKEN_HERE
META_API_VERSION=v21.0
META_BUSINESS_ID=651286011395964

# MUST equal the marketing backend's JWT_SECRET (default "dev-secret") so its
# login tokens validate here — unified auth, metaapi has no login of its own.
JWT_SECRET=dev-secret
